# Copy to .env.local and fill in. .env.local is gitignored — never commit real values.

# --- ClickHouse Cloud ---
# From the ClickHouse Cloud console → your service → "Connect".
CLICKHOUSE_URL=https://xxxxxxxx.europe-west4.gcp.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=bwt

# --- Trigger.dev ---
# Project ref from the Trigger.dev dashboard (looks like proj_xxxxxxxx).
TRIGGER_PROJECT_REF=
# Secret key, from Dashboard → API keys. Server-side only.
TRIGGER_SECRET_KEY=

# --- Anthropic ---
# For the app's own model calls — separate from any Claude Code subscription.
ANTHROPIC_API_KEY=
