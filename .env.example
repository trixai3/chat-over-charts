# Copy to .env.local and fill in. .env.local is gitignored — never commit real values.

# --- ClickHouse Cloud ---
# console.clickhouse.cloud → your service → "Connect" → HTTPS.
# NOTE: the database name is case-sensitive.
CLICKHOUSE_URL=https://xxxxxxxx.europe-west4.gcp.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=HACK_BWT

# --- Trigger.dev ---
# Project ref from the Trigger.dev dashboard (looks like proj_xxxxxxxx).
TRIGGER_PROJECT_REF=
# Secret key, from Dashboard → API keys. Server-side only.
TRIGGER_SECRET_KEY=

# --- Model ---
# MODEL_PROVIDER picks the path at runtime: "openrouter" | "anthropic"
# Dev on something cheap via OpenRouter; switch to a strong model for the demo,
# because the tool loop is only as reliable as the model driving it.
MODEL_PROVIDER=openrouter

# OpenRouter — one key, any model. https://openrouter.ai/keys
OPENROUTER_API_KEY=
# e.g. deepseek/deepseek-chat, anthropic/claude-sonnet-4-5, openai/gpt-4o
OPENROUTER_MODEL=deepseek/deepseek-chat

# Anthropic direct — needed only if MODEL_PROVIDER=anthropic.
# Buys native prompt caching (cache reads ~10% of input price).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
